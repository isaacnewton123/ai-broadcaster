# ─── Telegram Bot API ────────────────────────────────────────────────────────
# Didapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Username/ID Channel Publik Anda (misal: @nyarikerja_online)
TELEGRAM_PUBLISH_CHANNEL=@your_channel_here

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Didapatkan dari https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Connection string yang SAMA PERSIS dengan bot scraper Anda
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=nyarikerja_db
MONGODB_JOBS_COLLECTION=jobs
MONGODB_HISTORY_COLLECTION=broadcast_history

# ─── Polling & Throttle ──────────────────────────────────────────────────────
# Interval pengecekan loker baru (dalam detik). Default: 300 (5 menit)
POLL_INTERVAL_SECONDS=300
# Jeda antar posting ke Telegram (dalam detik). Default: 15
THROTTLE_DELAY_SECONDS=15

# ─── Server Port ─────────────────────────────────────────────────────────────
# Port untuk health check server (Render default: 10000)
PORT=10000
